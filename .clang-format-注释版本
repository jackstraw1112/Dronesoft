---
# clang-format configuration for this project.
# Note:
# - This file uses YAML syntax.
# - Lines starting with '#' are comments.
# - "ColumnLimit: 0" means no forced line wrapping.

# 应用到 C++ 文件。
Language: Cpp
# 基础风格：以 LLVM 为基线，再做项目化定制。
BasedOnStyle: LLVM
# 访问控制符（public/private/protected）向左回退 4 空格。
AccessModifierOffset: -4
# 不做连续对齐，减少大范围无意义 diff。
AlignConsecutiveAssignments: false
# 不对齐连续声明，避免变量名长度变化导致大面积重排。
AlignConsecutiveDeclarations: false
# 运算表达式不做额外垂直对齐，保持最小变更原则。
AlignOperands: false
# 尾注释对齐，增强可读性。
AlignTrailingComments: true
# 允许短代码块单行；函数与 if 保持多行更清晰。
AllowShortBlocksOnASingleLine: true
# 短函数不压缩成单行（即使只有一行逻辑）。
AllowShortFunctionsOnASingleLine: None
# 短 if 也不压缩成单行，统一控制流风格。
AllowShortIfStatementsOnASingleLine: false
# 函数定义返回类型后不强制换行。
AlwaysBreakAfterDefinitionReturnType: false
# 模板声明总是换行，减少长模板签名的拥挤感。
AlwaysBreakTemplateDeclarations: Yes
# 自定义大括号换行策略（配合 BreakBeforeBraces: Custom）。
BraceWrapping: 
  # Use Allman-style brace wrapping for most blocks.
  # case 标签后换行再开花括号。
  AfterCaseLabel: true
  # class 定义的大括号另起一行。
  AfterClass: true
  # 控制语句（if/for/while）的大括号另起一行。
  AfterControlStatement: true
  # enum 定义的大括号另起一行。
  AfterEnum: true
  # 函数定义的大括号另起一行。
  AfterFunction: true
  # namespace 的大括号另起一行。
  AfterNamespace: true
  # struct 定义的大括号另起一行。
  AfterStruct: true
  # union 定义的大括号另起一行。
  AfterUnion: true
  # extern block 的大括号另起一行。
  AfterExternBlock: true
  # catch 前保持换行。
  BeforeCatch: true
  # else 前保持换行。
  BeforeElse: true
  # lambda 体前换行。
  BeforeLambdaBody: true
  # do...while 的 while 前换行。
  BeforeWhile: true
  # 空函数不拆分为多行。
  SplitEmptyFunction: false
  # 空结构体不拆分为多行。
  SplitEmptyRecord: false
  # 空命名空间不拆分为多行。
  SplitEmptyNamespace: false
# 使用自定义花括号策略。
BreakBeforeBraces: Custom
# 构造函数初始化列表的逗号前不强制断行。
BreakConstructorInitializersBeforeComma: false
# 不强制列宽换行，交由开发者按语义控制。
ColumnLimit: 0
# 初始化列表可按上下文排版，不强制“全单行或每项一行”。
ConstructorInitializerAllOnOneLineOrOnePerLine: false
# 换行后的续行缩进宽度。
ContinuationIndentWidth: 8
# include 分组规则。
IncludeCategories: 
  # Include sorting order:
  # 1) system headers <...>
  # 2) local headers "..."
  # 3) fallback
  # 系统头文件优先级最高。
  - Regex: '^<.*'
    Priority: 1
  # 本地头文件次优先级。
  - Regex: '^".*'
    Priority: 2
  # 其他情况兜底分组。
  - Regex: '.*'
    Priority: 3
# 识别“主文件”的正则（含 test/unittest 后缀）。
IncludeIsMainRegex: '([-_](test|unittest))?$'
# switch/case 相关缩进策略。
# case 内部代码块继续缩进。
IndentCaseBlocks: true
# case 标签本身缩进到 switch 内层级。
IndentCaseLabels: true
# 预处理指令保持在 # 前可缩进。
IndentPPDirectives: BeforeHash
# 缩进与 tab 宽度统一为 4。
IndentWidth: 4
# 文件末尾自动补换行，避免工具链告警。
InsertNewlineAtEOF: true
# 宏代码块标记（当前未使用）。
MacroBlockBegin: ''
MacroBlockEnd: ''
# namespace 内部继续缩进。
NamespaceIndentation: All
# 括号与泛型尖括号空格策略：统一紧凑风格。
# 空括号内不留空格：func()。
SpaceInEmptyParentheses: false
# 模板尖括号不加空格：std::vector<int>。
SpacesInAngles: false
# 条件语句括号内不加空格：if(a)。
SpacesInConditionalStatement: false
# C 风格强转括号内不加空格：(int)x。
SpacesInCStyleCastParentheses: false
# 普通括号内不加空格：foo(a, b)。
SpacesInParentheses: false
# tab 显示宽度（若存在 tab 字符时的视觉宽度）。
TabWidth: 4
...
